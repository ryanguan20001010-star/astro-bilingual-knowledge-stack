---
import { getLocaleFromUrl, getLocalizedPath } from '../utils/i18n';

const locale = getLocaleFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

const targetLocale = locale === 'en' ? 'zh' : 'en';
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPathWithoutBase = currentPath.startsWith(basePath)
  ? currentPath.slice(basePath.length) || '/'
  : currentPath;
const baseHref = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const targetPath = `${baseHref}${getLocalizedPath(currentPathWithoutBase, targetLocale).replace(/^\//, '')}`;
---

<a 
  href={targetPath} 
  class="flex items-center gap-2 px-3 py-1.5 text-sm rounded-md hover:bg-neutral-100 transition-colors"
  aria-label="Toggle language"
>
  <span class="font-medium">{locale === 'en' ? '中' : 'EN'}</span>
</a>
