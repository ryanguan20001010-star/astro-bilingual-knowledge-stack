---
import { getLocaleFromUrl, getLocalizedPath } from '../utils/i18n';

const locale = getLocaleFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

const targetLocale = locale === 'en' ? 'zh' : 'en';
const targetPath = `${import.meta.env.BASE_URL}${getLocalizedPath(currentPath, targetLocale).replace(/^\//, '')}`;
---

<a 
  href={targetPath} 
  class="flex items-center gap-2 px-3 py-1.5 text-sm rounded-md hover:bg-neutral-100 transition-colors"
  aria-label="Toggle language"
>
  <span class="font-medium">{locale === 'en' ? '中' : 'EN'}</span>
</a>
