---
export const prerender = true;
const basePath = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const englishHome = `${basePath}en/`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${englishHome}`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Astro Bilingual Knowledge Stack</title>
    <link rel="canonical" href={englishHome} />
  </head>
  <body>
    <p><a href={englishHome}>Continue to the English site</a></p>
  </body>
</html>
