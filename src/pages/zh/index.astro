---
import BaseLayout from '../../layouts/BaseLayout.astro';
const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, '')}`;
---

<BaseLayout title="双语知识栈" description="一个开源的 Astro 双语网站工具栈。">
  <section class="py-12">
    <h1 class="text-4xl font-bold mb-4">欢迎来到双语知识栈</h1>
    <p class="text-lg text-neutral-600 mb-8">
      一个用于维护 Astro 双语知识站的最小启动模板。
    </p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <a href={withBase('/zh/blog')} class="p-6 border border-neutral-200 rounded-lg hover:border-accent transition-colors">
        <h2 class="text-xl font-semibold mb-2">博客</h2>
        <p class="text-neutral-500">阅读我们的最新文章和更新。</p>
      </a>
      <a href={withBase('/zh/docs')} class="p-6 border border-neutral-200 rounded-lg hover:border-accent transition-colors">
        <h2 class="text-xl font-semibold mb-2">文档</h2>
        <p class="text-neutral-500">探索知识库和词汇表。</p>
      </a>
    </div>
  </section>
</BaseLayout>
