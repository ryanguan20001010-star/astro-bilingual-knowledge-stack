{
  "name": "astro-bilingual-knowledge-stack",
  "description": "A minimal bilingual Astro starter for knowledge sites.",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.1",
  "keywords": [
    "astro",
    "astro-theme",
    "i18n",
    "bilingual",
    "ssg",
    "documentation"
  ],
  "license": "MIT",
  "author": "ryanguan20001010-star",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryanguan20001010-star/astro-bilingual-knowledge-stack.git"
  },
  "homepage": "https://github.com/ryanguan20001010-star/astro-bilingual-knowledge-stack#readme",
  "bugs": {
    "url": "https://github.com/ryanguan20001010-star/astro-bilingual-knowledge-stack/issues"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check:content": "node tools/check-content/run.mjs",
    "check:links": "node tools/check-links/run.mjs",
    "check:images": "node tools/check-images/run.mjs",
    "check:seo": "node tools/check-seo/run.mjs",
    "smoke:prod": "node tools/smoke-production/run.mjs",
    "update-log": "node tools/update-log/run.mjs",
    "test": "vitest run",
    "verify": "pnpm run check:content && pnpm run check:links && pnpm run check:images && pnpm run check:seo && pnpm test && pnpm run build"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.0.2",
    "@astrojs/partytown": "^2.1.2",
    "@astrojs/react": "^4.1.2",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^5.1.3",
    "astro": "^5.1.1",
    "lucide-react": "^0.468.0",
    "pagefind": "^1.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "vitest": "^4.0.15",
    "wrangler": "^4.59.2"
  }
}
